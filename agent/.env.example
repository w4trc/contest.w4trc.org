# Copy to .env and fill in values (or export directly in your shell)

# URL of the deployed Cloudflare Worker (no trailing slash)
WORKER_URL=https://w4trc-fieldday.workers.dev

# Shared secret — must match what you set with: wrangler secret put INGEST_SECRET
INGEST_SECRET=changeme

# N1MM+ broadcast port (default 12060)
UDP_PORT=12060

# Optional: custom paths for the disk queue
# QUEUE_FILE=./queue.jsonl
# CURSOR_FILE=./cursor.txt
